{
  "name": "obsidian-tui-reader",
  "version": "0.1.0",
  "description": "A read-only terminal UI for browsing and reading an Obsidian vault.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "obsidian-tui-reader": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsc",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "install:global": "sh ./install.sh",
    "uninstall:global": "sh ./uninstall.sh"
  },
  "dependencies": {
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.20",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
